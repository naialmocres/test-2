<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Document Library</title>
  <style>
    /* ─── Tokens ─────────────────────────────── */
    :root {
      --navy:       #0D2240;
      --navy-mid:   #1A3A60;
      --cyan:       #1E88E5;
      --cyan-light: #E8F4FD;
      --white:      #FFFFFF;
      --gray-50:    #F7F9FC;
      --gray-100:   #EEF2F7;
      --gray-200:   #D5DEE9;
      --gray-400:   #8FA3BC;
      --gray-600:   #4A6180;
      --gray-800:   #1E2D3D;
      --green:      #22A06B;
      --amber:      #E2A400;
      --red:        #D93B2B;
      --radius:     8px;
      --shadow:     0 2px 8px rgba(13,34,64,.10);
      --shadow-md:  0 4px 16px rgba(13,34,64,.14);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--gray-50);
      color: var(--gray-800);
      min-height: 100vh;
    }

    /* ─── Top Bar ─────────────────────────────── */
    header {
      background: var(--navy);
      color: var(--white);
      padding: 0 32px;
      height: 60px;
      display: flex;
      align-items: center;
      gap: 12px;
      box-shadow: var(--shadow-md);
    }
    header .logo-mark {
      width: 32px; height: 32px;
      background: var(--cyan);
      border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 14px; letter-spacing: -0.5px;
    }
    header h1 { font-size: 16px; font-weight: 600; letter-spacing: 0.3px; }
    header span { color: var(--gray-400); font-size: 13px; margin-left: auto; }

    /* ─── Layout ─────────────────────────────── */
    .page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 28px 24px;
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 24px;
      align-items: start;
    }

    /* ─── Sidebar Filters ─────────────────────── */
    .sidebar {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
      position: sticky;
      top: 24px;
    }
    .sidebar-header {
      background: var(--navy);
      color: var(--white);
      padding: 14px 18px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.6px;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .sidebar-header svg { opacity: .7; }

    .filter-section { border-bottom: 1px solid var(--gray-100); }
    .filter-section:last-child { border-bottom: none; }

    .filter-label {
      padding: 12px 18px 8px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--gray-400);
    }
    .filter-options { padding: 0 12px 12px; }

    .chip-group { display: flex; flex-wrap: wrap; gap: 6px; }

    .chip {
      padding: 5px 12px;
      border-radius: 20px;
      border: 1.5px solid var(--gray-200);
      background: var(--white);
      font-size: 12px;
      font-weight: 500;
      color: var(--gray-600);
      cursor: pointer;
      transition: all .15s;
      user-select: none;
    }
    .chip:hover { border-color: var(--cyan); color: var(--cyan); }
    .chip.active {
      border-color: var(--cyan);
      background: var(--cyan-light);
      color: var(--cyan);
    }

    .clear-btn {
      display: block;
      width: calc(100% - 24px);
      margin: 0 12px 14px;
      padding: 8px;
      background: none;
      border: 1.5px solid var(--gray-200);
      border-radius: var(--radius);
      font-size: 12px;
      font-weight: 600;
      color: var(--gray-600);
      cursor: pointer;
      transition: all .15s;
      text-align: center;
    }
    .clear-btn:hover { border-color: var(--red); color: var(--red); background: #fff5f5; }

    /* ─── Main Content ─────────────────────────── */
    .main {}

    .toolbar {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .search-wrap {
      flex: 1;
      position: relative;
    }
    .search-wrap svg {
      position: absolute;
      left: 12px; top: 50%; transform: translateY(-50%);
      color: var(--gray-400);
      pointer-events: none;
    }
    .search-input {
      width: 100%;
      padding: 10px 14px 10px 38px;
      border: 1.5px solid var(--gray-200);
      border-radius: var(--radius);
      font-size: 14px;
      background: var(--white);
      color: var(--gray-800);
      outline: none;
      transition: border-color .15s;
    }
    .search-input:focus { border-color: var(--cyan); }
    .search-input::placeholder { color: var(--gray-400); }

    .sort-select {
      padding: 10px 14px;
      border: 1.5px solid var(--gray-200);
      border-radius: var(--radius);
      font-size: 13px;
      background: var(--white);
      color: var(--gray-800);
      outline: none;
      cursor: pointer;
    }
    .sort-select:focus { border-color: var(--cyan); }

    /* ─── Result Count ─────────────────────────── */
    .result-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--gray-200);
    }
    .result-count { font-size: 13px; color: var(--gray-600); }
    .result-count strong { color: var(--gray-800); }

    .active-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .active-tag {
      display: flex; align-items: center; gap: 4px;
      padding: 3px 10px 3px 10px;
      background: var(--cyan-light);
      border: 1px solid var(--cyan);
      border-radius: 20px;
      font-size: 11px;
      color: var(--cyan);
      font-weight: 600;
    }
    .active-tag button {
      background: none; border: none;
      color: var(--cyan); cursor: pointer;
      font-size: 13px; line-height: 1;
      padding: 0; margin-left: 2px;
    }
    .active-tag button:hover { color: var(--navy); }

    /* ─── Document Grid ─────────────────────────── */
    .doc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 14px;
    }

    .doc-card {
      background: var(--white);
      border: 1.5px solid var(--gray-200);
      border-radius: var(--radius);
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      box-shadow: var(--shadow);
      transition: box-shadow .15s, border-color .15s, transform .15s;
      cursor: pointer;
      text-decoration: none;
    }
    .doc-card:hover {
      box-shadow: var(--shadow-md);
      border-color: var(--cyan);
      transform: translateY(-2px);
    }

    .doc-icon {
      width: 40px; height: 40px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }
    .doc-icon.pdf   { background: #FDEAEA; }
    .doc-icon.docx  { background: #E8F0FE; }
    .doc-icon.xlsx  { background: #E6F4EA; }
    .doc-icon.pptx  { background: #FFF3E0; }

    .doc-card h3 { font-size: 14px; font-weight: 600; color: var(--gray-800); line-height: 1.3; }
    .doc-card p  { font-size: 12px; color: var(--gray-600); line-height: 1.4; flex: 1; }

    .doc-meta { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
    .meta-tag {
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.3px;
    }
    .meta-tag.dept  { background: #EEF2FF; color: #4338CA; }
    .meta-tag.role  { background: #F0FDF4; color: #166534; }
    .meta-tag.title { background: #FFF7ED; color: #9A3412; }

    .doc-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 8px;
      border-top: 1px solid var(--gray-100);
      font-size: 11px;
      color: var(--gray-400);
    }

    /* ─── Empty State ─────────────────────────── */
    .empty {
      grid-column: 1 / -1;
      text-align: center;
      padding: 60px 20px;
      color: var(--gray-400);
    }
    .empty svg { opacity: .3; margin-bottom: 16px; }
    .empty h3 { font-size: 16px; color: var(--gray-600); margin-bottom: 6px; }
    .empty p  { font-size: 13px; }

    @media (max-width: 760px) {
      .page { grid-template-columns: 1fr; }
      .sidebar { position: static; }
    }
  </style>
</head>
<body>

<header>
  <div class="logo-mark">DL</div>
  <h1>Document Library</h1>
  <span id="headerCount">Loading…</span>
</header>

<div class="page">

  <!-- ── SIDEBAR ── -->
  <aside class="sidebar">
    <div class="sidebar-header">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      Filters
    </div>

    <!-- Department -->
    <div class="filter-section">
      <div class="filter-label">Department</div>
      <div class="filter-options">
        <div class="chip-group" id="dept-chips"></div>
      </div>
    </div>

    <!-- Job Title -->
    <div class="filter-section">
      <div class="filter-label">Job Title</div>
      <div class="filter-options">
        <div class="chip-group" id="title-chips"></div>
      </div>
    </div>

    <!-- Role -->
    <div class="filter-section">
      <div class="filter-label">Role</div>
      <div class="filter-options">
        <div class="chip-group" id="role-chips"></div>
      </div>
    </div>

    <button class="clear-btn" onclick="clearAll()">✕ Clear all filters</button>
  </aside>

  <!-- ── MAIN ── -->
  <main class="main">
    <div class="toolbar">
      <div class="search-wrap">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input class="search-input" type="text" id="searchInput" placeholder="Search documents…" oninput="renderDocs()" />
      </div>
      <select class="sort-select" id="sortSelect" onchange="renderDocs()">
        <option value="name-asc">Name A–Z</option>
        <option value="name-desc">Name Z–A</option>
        <option value="date-desc">Newest first</option>
        <option value="date-asc">Oldest first</option>
      </select>
    </div>

    <div class="result-bar">
      <div class="result-count"><strong id="countLabel">0</strong> documents</div>
      <div class="active-tags" id="activeTags"></div>
    </div>

    <div class="doc-grid" id="docGrid"></div>
  </main>
</div>

<script>
  /* ─── Data ─────────────────────────────────── */
  const docs = [
    { id:1,  name:"Employee Onboarding Guide",     type:"pdf",  desc:"Step-by-step onboarding checklist for all new hires.",          dept:"HR",          title:"HR Coordinator",    role:"Manager",       date:"2024-11-01" },
    { id:2,  name:"Benefits & Compensation Policy",type:"docx", desc:"Full breakdown of health, dental, and PTO packages.",           dept:"HR",          title:"HR Director",       role:"Employee",      date:"2024-09-15" },
    { id:3,  name:"Q4 Budget Forecast",            type:"xlsx", desc:"Department-level budget projections through December.",         dept:"Finance",     title:"Financial Analyst", role:"Manager",       date:"2025-01-10" },
    { id:4,  name:"Accounts Payable SOP",          type:"docx", desc:"Standard operating procedure for invoice processing.",          dept:"Finance",     title:"Accountant",        role:"Employee",      date:"2024-08-22" },
    { id:5,  name:"IT Security Policy",            type:"pdf",  desc:"Acceptable use policy for corporate devices and systems.",      dept:"IT",          title:"IT Manager",        role:"Admin",         date:"2025-02-01" },
    { id:6,  name:"Software Request Form",         type:"docx", desc:"Submit requests for new software licenses or tools.",           dept:"IT",          title:"IT Coordinator",    role:"Employee",      date:"2024-07-30" },
    { id:7,  name:"Q3 Sales Performance Review",   type:"pptx", desc:"Regional performance breakdown and quota attainment by rep.",   dept:"Sales",       title:"Sales Manager",     role:"Manager",       date:"2024-10-05" },
    { id:8,  name:"Sales Playbook 2025",           type:"pdf",  desc:"Objection handling, discovery scripts, and close strategies.",  dept:"Sales",       title:"Sales Rep",         role:"Employee",      date:"2025-01-20" },
    { id:9,  name:"CRM User Guide",                type:"docx", desc:"How to log activities, manage pipelines, and generate reports.", dept:"Sales",       title:"Sales Rep",         role:"Employee",      date:"2024-06-14" },
    { id:10, name:"Brand Style Guide",             type:"pdf",  desc:"Logo usage, color palette, typography, and tone of voice.",     dept:"Marketing",   title:"Brand Designer",    role:"Employee",      date:"2024-12-01" },
    { id:11, name:"Campaign ROI Tracker",          type:"xlsx", desc:"Track spend, impressions, conversions, and ROI per campaign.",  dept:"Marketing",   title:"Marketing Analyst", role:"Manager",       date:"2025-01-08" },
    { id:12, name:"Press Release Template",        type:"docx", desc:"Standard template for external announcements and launches.",    dept:"Marketing",   title:"PR Specialist",     role:"Employee",      date:"2024-05-19" },
    { id:13, name:"Engineering Runbook",           type:"pdf",  desc:"On-call procedures for service outages and incident response.", dept:"Engineering", title:"DevOps Engineer",   role:"Admin",         date:"2025-02-15" },
    { id:14, name:"API Documentation v3.2",        type:"docx", desc:"Endpoints, authentication, and response schema reference.",     dept:"Engineering", title:"Software Engineer", role:"Employee",      date:"2025-01-30" },
    { id:15, name:"Sprint Planning Template",      type:"xlsx", desc:"Velocity tracking and story-point estimation worksheet.",       dept:"Engineering", title:"Scrum Master",      role:"Manager",       date:"2024-11-22" },
    { id:16, name:"Vendor Contract Template",      type:"docx", desc:"Standard NDA and service agreement for new vendors.",           dept:"Legal",       title:"Legal Counsel",     role:"Admin",         date:"2024-09-01" },
    { id:17, name:"Compliance Checklist",          type:"pdf",  desc:"Quarterly review items for regulatory compliance audit.",       dept:"Legal",       title:"Compliance Officer",role:"Manager",       date:"2025-01-15" },
    { id:18, name:"Training Curriculum Overview",  type:"pptx", desc:"Learning paths and course catalog for all departments.",        dept:"HR",          title:"L&D Specialist",    role:"Manager",       date:"2024-10-28" },
  ];

  const icons = { pdf:"📄", docx:"📝", xlsx:"📊", pptx:"📋" };

  /* ─── Filter state ─────────────────────────── */
  const filters = { dept: new Set(), title: new Set(), role: new Set() };

  /* ─── Build chips ─────────────────────────── */
  function unique(key) { return [...new Set(docs.map(d => d[key]))].sort(); }

  function buildChips(containerId, key, values) {
    const el = document.getElementById(containerId);
    el.innerHTML = values.map(v =>
      `<div class="chip" data-key="${key}" data-val="${v}" onclick="toggleChip(this)">${v}</div>`
    ).join('');
  }

  buildChips('dept-chips',  'dept',  unique('dept'));
  buildChips('title-chips', 'title', unique('title'));
  buildChips('role-chips',  'role',  unique('role'));

  function toggleChip(el) {
    const key = el.dataset.key;
    const val = el.dataset.val;
    if (filters[key].has(val)) { filters[key].delete(val); el.classList.remove('active'); }
    else                       { filters[key].add(val);    el.classList.add('active');    }
    renderDocs();
  }

  function clearAll() {
    ['dept','title','role'].forEach(k => filters[k].clear());
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    document.getElementById('searchInput').value = '';
    renderDocs();
  }

  /* ─── Remove active tag ─────────────────────── */
  function removeTag(key, val) {
    filters[key].delete(val);
    document.querySelectorAll(`.chip[data-key="${key}"][data-val="${val}"]`)
      .forEach(c => c.classList.remove('active'));
    renderDocs();
  }

  /* ─── Render ─────────────────────────────────── */
  function renderDocs() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    const sort  = document.getElementById('sortSelect').value;

    let results = docs.filter(d => {
      const matchDept  = filters.dept.size  === 0 || filters.dept.has(d.dept);
      const matchTitle = filters.title.size === 0 || filters.title.has(d.title);
      const matchRole  = filters.role.size  === 0 || filters.role.has(d.role);
      const matchQ     = !query ||
        d.name.toLowerCase().includes(query) ||
        d.desc.toLowerCase().includes(query) ||
        d.dept.toLowerCase().includes(query);
      return matchDept && matchTitle && matchRole && matchQ;
    });

    results.sort((a, b) => {
      if (sort === 'name-asc')  return a.name.localeCompare(b.name);
      if (sort === 'name-desc') return b.name.localeCompare(a.name);
      if (sort === 'date-desc') return new Date(b.date) - new Date(a.date);
      if (sort === 'date-asc')  return new Date(a.date) - new Date(b.date);
    });

    /* Active tags */
    const tagsEl = document.getElementById('activeTags');
    const allActive = [
      ...[ ...filters.dept  ].map(v => ({ key:'dept',  val:v })),
      ...[ ...filters.title ].map(v => ({ key:'title', val:v })),
      ...[ ...filters.role  ].map(v => ({ key:'role',  val:v })),
    ];
    tagsEl.innerHTML = allActive.map(t =>
      `<span class="active-tag">${t.val}
         <button onclick="removeTag('${t.key}','${t.val}')">×</button>
       </span>`
    ).join('');

    /* Count */
    document.getElementById('countLabel').textContent = results.length;
    document.getElementById('headerCount').textContent = results.length + ' docs';

    /* Cards */
    const grid = document.getElementById('docGrid');
    if (results.length === 0) {
      grid.innerHTML = `
        <div class="empty">
          <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M9 13h6m-3-3v6M5 20h14a2 2 0 0 0 2-2V8l-5-5H5a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/>
          </svg>
          <h3>No documents found</h3>
          <p>Try adjusting your filters or search term.</p>
        </div>`;
      return;
    }

    grid.innerHTML = results.map(d => `
      <div class="doc-card">
        <div style="display:flex;align-items:center;gap:12px">
          <div class="doc-icon ${d.type}">${icons[d.type]}</div>
          <h3>${d.name}</h3>
        </div>
        <p>${d.desc}</p>
        <div class="doc-meta">
          <span class="meta-tag dept">${d.dept}</span>
          <span class="meta-tag title">${d.title}</span>
          <span class="meta-tag role">${d.role}</span>
        </div>
        <div class="doc-footer">
          <span>.${d.type.toUpperCase()}</span>
          <span>${formatDate(d.date)}</span>
        </div>
      </div>
    `).join('');
  }

  function formatDate(s) {
    return new Date(s).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
  }

  renderDocs();
</script>
</body>
</html>
